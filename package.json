{
  "name": "@lapidist/eslint-config",
  "version": "1.0.0",
  "description": "Shared ESLint configuration for the Lapidist ecosystem",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./node": "./node.js"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.3",
  "keywords": ["eslint", "config", "lapidist"],
  "author": "Brett Dorrans <hello@lapidist.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bylapidist/eslint-config.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "eslint": "10.4.1"
  },
  "scripts": {
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "eslint": "10.4.1"
  },
  "files": ["index.js", "node.js"],
  "publishConfig": {
    "access": "public"
  }
}
